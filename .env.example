# ──────────────────────────────────────────────────────────────────
# WishMotors Telegram Analyzer — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────

# Bot token from @BotFather
BOT_TOKEN=

# Your Telegram Supergroup ID (negative number, e.g. -1001234567890)
# Send any message in the group then check with @userinfobot or the API
GROUP_ID=

# Forum Topic Thread IDs
# To find a topic ID: right-click a message in that topic → Copy Link
# The number after the last / is the message_thread_id
SALES_TOPIC_ID=
ORDERS_TOPIC_ID=
EXPENSES_TOPIC_ID=
CAPITAL_TOPIC_ID=

# ── Database ───────────────────────────────────────────────────────
DATABASE_PATH=data/wishmotors.db

# ── Scheduled report ──────────────────────────────────────────────
TIMEZONE=Asia/Tbilisi
REPORT_WEEKDAY=sun        # mon tue wed thu fri sat sun
REPORT_HOUR=22
REPORT_MINUTE=0

# ── Stock warning threshold ───────────────────────────────────────
MIN_STOCK_THRESHOLD=20
