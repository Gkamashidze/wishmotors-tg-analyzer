# ──────────────────────────────────────────────────────────────────
# WishMotors Telegram Analyzer — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────

# Bot token from @BotFather
BOT_TOKEN=

# Your Telegram Supergroup ID (negative number, e.g. -1001234567890)
GROUP_ID=

# Forum Topic Thread IDs
# To find a topic ID: right-click a message in that topic → Copy Link
# The number after the last / is the message_thread_id
SALES_TOPIC_ID=
ORDERS_TOPIC_ID=
EXPENSES_TOPIC_ID=
CAPITAL_TOPIC_ID=
NISIAS_TOPIC_ID=
INVENTORY_TOPIC_ID=

# ── PostgreSQL connection URL ──────────────────────────────────────
# Railway provides this automatically as ${{Postgres.DATABASE_URL}}
# Local example: postgresql://user:password@localhost:5432/wishmotors
DATABASE_URL=

# ── Authorization ─────────────────────────────────────────────────
# Comma-separated Telegram user IDs that may use bot commands.
# Find your ID by messaging @userinfobot
ADMIN_IDS=

# ── Scheduled report ──────────────────────────────────────────────
TIMEZONE=Asia/Tbilisi
REPORT_WEEKDAY=sun        # mon tue wed thu fri sat sun
REPORT_HOUR=22
REPORT_MINUTE=0

# ── Stock warning threshold ───────────────────────────────────────
MIN_STOCK_THRESHOLD=20

# ── Excel upload limit (bytes) ────────────────────────────────────
MAX_EXCEL_BYTES=5242880   # 5 MB

# ── Telethon (audit_live.py only — NOT needed for the bot) ────────
# Get these from https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# ── AI Financial Manager (optional) ───────────────────────────────
# Anthropic API key (https://console.anthropic.com).
# When set, weekly /report includes an AI-generated business analysis.
# When unset, the report is delivered exactly as before — no AI block.
ANTHROPIC_API_KEY=
