# ──────────────────────────────────────────────────────────────────
# WishMotors Dashboard — Environment Variables
# Copy this to .env.local and fill in real values. NEVER commit .env.local.
# ──────────────────────────────────────────────────────────────────

# PostgreSQL connection (same as main bot)
# On Railway: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:password@host:port/database

# Force SSL (required for Railway & production Postgres)
PGSSL=true

# REQUIRED IN PRODUCTION: simple basic-auth gate (user:password).
# In production (NODE_ENV=production) if this is missing, the dashboard returns
# 503 and refuses to serve any page — protects against accidental exposure.
# Format: "admin:LongRandomPassword"
DASHBOARD_BASIC_AUTH=

# ── Public catalog contact links ──────────────────────────────────────────────
# Shown on product detail pages as CTA buttons (WhatsApp / Telegram / Phone).
# No quotes, no leading plus for WHATSAPP_PHONE (e.g. 995555123456).

# WhatsApp number — digits only, country code included, no "+" prefix
NEXT_PUBLIC_WHATSAPP_PHONE=995555123456

# Telegram bot username — without "@"
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=wishmotors_bot

# Display phone number shown on the "Call" button (human-readable format)
NEXT_PUBLIC_CONTACT_PHONE=+995 555 12 34 56

# Full base URL of the catalog (no trailing slash). Used in canonical URLs, sitemap, WhatsApp share.
# Production: https://wishmotors.ge
# Local dev:  http://localhost:3000
NEXT_PUBLIC_CATALOG_BASE_URL=https://www.wishmotors.ge

# Comma-separated list of custom domains allowed to make Server Actions requests.
# Add www.wishmotors.ge here so Next.js accepts requests from the custom domain.
DASHBOARD_ALLOWED_ORIGINS=www.wishmotors.ge

# ── Footer & About page — business info ──────────────────────────────────────
# All optional — missing vars hide the corresponding row/link gracefully.

# Contact email (shown in footer)
NEXT_PUBLIC_CONTACT_EMAIL=

# Physical address (footer column B)
NEXT_PUBLIC_BUSINESS_ADDRESS=თბილისი, ............... ქ. N..

# Opening hours (footer column B)
NEXT_PUBLIC_BUSINESS_HOURS=ორშ-შაბ 10:00-19:00, კვ დასვენება

# Google Maps link (footer "Google Maps-ზე ნახვა →")
NEXT_PUBLIC_GOOGLE_MAPS_URL=

# Google Maps embed src URL (About page iframe). Paste the src= value from Maps > Share > Embed.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED=

# Social media links (footer quick links)
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=

# About page stats (shown with sensible defaults if missing)
# Years in business — e.g. "5"
NEXT_PUBLIC_YEARS_IN_BUSINESS=5
# Happy customers count — e.g. "1000"
NEXT_PUBLIC_HAPPY_CUSTOMERS=1000+
# Products in stock count — e.g. "500"
NEXT_PUBLIC_PRODUCTS_IN_STOCK=500+

# ── Google Drive (product image uploads) ─────────────────────────────────────
# Required for the "ფოტოს ატვირთვა" button in the products edit modal.
# If these are missing, the upload button returns a 503 error.
#
# Setup steps:
#   1. console.cloud.google.com → New project → Enable "Google Drive API"
#   2. IAM & Admin → Service Accounts → Create → download JSON key
#   3. Google Drive-ზე შექმენი საქაღალდე (e.g. "wishmotors-products")
#   4. Share that folder with the service account email (Editor access)
#   5. Copy the folder ID from its URL: drive.google.com/drive/folders/FOLDER_ID

# Full service account JSON — paste the entire contents of the downloaded .json key file,
# minified to one line (remove newlines). Example:
# {"type":"service_account","project_id":"...","private_key_id":"...",...}
GOOGLE_SERVICE_ACCOUNT_JSON=

# Google Drive folder ID where images will be uploaded
GOOGLE_DRIVE_FOLDER_ID=
